{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "400000",
    "CLAUDE_CODE_AUTO_BACKGROUND_TASKS": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "permissions": {
    "deny": ["Read(**/.env)", "Read(**/.env.*)", "Read(**/*.pem)", "Read(**/*.key)"]
  },
  "sandbox": {
    "grants": {
      "r2-publish": {
        "env": [
          { "name": "ACCESS_KEY_ID_TURNTROUT_MEDIA", "envchain": "cloudflare" },
          { "name": "SECRET_ACCESS_TURNTROUT_MEDIA", "envchain": "cloudflare" },
          { "name": "S3_ENDPOINT_ID_TURNTROUT_MEDIA", "envchain": "cloudflare" }
        ],
        "hosts": [
          { "host": "${S3_ENDPOINT_ID_TURNTROUT_MEDIA}.r2.cloudflarestorage.com", "rw": true },
          { "host": "assets.turntrout.com" },
          { "host": "turntrout.com" }
        ]
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-setup.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash(git push*|gh pr create*)",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/safe-launch.sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-push-check.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-narrative-comments.sh"
          }
        ]
      }
    ]
  }
}
