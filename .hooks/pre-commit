#!/bin/bash
# Pre-commit hook: Format and lint staged files via lint-staged.
# When lint-staged is not installed (non-Node projects), exits 0 without
# formatting — CI's pre-commit run still covers the pushed files.

set -euo pipefail

git_root=$(git rev-parse --show-toplevel)

# Format staged files FIRST, so fixable issues (trailing whitespace, EOF
# newlines, import order) are auto-corrected and re-staged before the gate at
# the end rejects on them. lint-staged runs prettier/markdownlint/eslint/etc.
# and re-stages whatever they modify.
if [ -f "$git_root/package.json" ] && [ -f "$git_root/node_modules/.bin/lint-staged" ]; then
  if command -v pnpm >/dev/null 2>&1; then
    pnpm exec lint-staged --allow-empty
  elif command -v npm >/dev/null 2>&1; then
    npx lint-staged --allow-empty
  fi
fi

# Run docformatter on staged Python files (can't run inside lint-staged
# because it requires uv run and doesn't work well with lint-staged's
# file passing)
staged_py_files=$(git diff --cached --name-only --diff-filter=ACM -- '*.py' || true)
if [ -n "$staged_py_files" ] && command -v uv >/dev/null 2>&1; then
  echo "$staged_py_files" | xargs uv run python -m docformatter \
    --in-place --config config/python/pyproject.toml 2>/dev/null || true
  # Re-stage any files that docformatter modified
  echo "$staged_py_files" | xargs git add
fi

