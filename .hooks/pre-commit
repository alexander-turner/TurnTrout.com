# Durable recovery snapshot before the destructive part. lint-staged (and the
# pre-commit auto-fixers it drives) hide your UNSTAGED tracked edits in an internal
# stash, rewrite the staged files, then restore that stash. A failed run — a
# non-auto-fixable lint error, or a stash-restore conflict when a fixer rewrote a
# file you also had unstaged — can DROP that hidden stash, silently reverting the
# unstaged work with no obvious way back. Only an unstaged tracked change is at
# risk (a fully-staged commit has nothing to lose), so snapshot just that case:
# `git stash create` writes a commit object WITHOUT touching the tree or the stash
# stack, pinned in a ref so it survives gc and is one `git checkout` away.
if ! git diff --quiet; then
  if _gb_snapshot=$(git stash create 2>/dev/null) && [[ -n "$_gb_snapshot" ]]; then
    git update-ref refs/gb/precommit-recovery "$_gb_snapshot" 2>/dev/null || true
    echo "pre-commit: unstaged edits present — saved recovery snapshot $_gb_snapshot (ref refs/gb/precommit-recovery). If this commit fails and your uncommitted edits vanish, restore them with: git checkout $_gb_snapshot -- <path>" >&2
  fi
fi

