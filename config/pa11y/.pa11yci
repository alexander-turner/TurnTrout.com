{
  "defaults": {
    "timeout": 30000,
    "chromeLaunchConfig": {
      "args": [
        "--no-sandbox",
        "--disable-setuid-sandbox",
        "--disable-dev-shm-usage"
      ]
    },
    "standard": "WCAG2AA",
    "runners": [
      "axe",
      "htmlcs"
    ],
    "hideElements": [
      ".ignore-pa11y",
      ".mermaid svg",
      ".spoiler-content",
      "#trout-ornament-container",
      ".katex-html"
    ],
    "ignore": [
      "frame-tested"
    ],
    "concurrency": 1
  }
}
