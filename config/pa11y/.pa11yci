{
  "defaults": {
    "timeout": 60000,
    "chromeLaunchConfig": {
      "args": [
        "--no-sandbox",
        "--disable-setuid-sandbox",
        "--disable-dev-shm-usage"
      ]
    },
    "standard": "WCAG2AA",
    "runners": [
      "axe",
      "htmlcs"
    ],
    "hideElements": [
      ".ignore-pa11y",
      ".mermaid svg",
      ".spoiler-content"
    ],
    "ignore": [
      "frame-tested"
    ],
    "useIncognitoBrowserContext": true,
    "concurrency": 2
  }
}
