{
  "name": "@alexander-turner/turntrout.com",
  "description": "A blog on AI, personal development, and living a good life.",
  "private": true,
  "type": "module",
  "prettier": {
    "printWidth": 100,
    "quoteProps": "as-needed",
    "trailingComma": "all",
    "tabWidth": 2,
    "semi": false
  },
  "author": "alexander-turner <alex@turntrout.com>",
  "license": "CC BY-SA 4.0",
  "homepage": "https://turntrout.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexander-turner/TurnTrout.com/"
  },
  "scripts": {
    "docs": "tsx quartz/bootstrap-cli.ts build --serve -d docs",
    "check": "tsc --noEmit -p config/typescript/tsconfig.json && pnpm prettier . --check --config config/prettier/.prettierrc --ignore-path config/prettier/.prettierignore && pnpm exec stylelint 'quartz/**/*.scss' --config config/stylelint/.stylelintrc.json",
    "format": "pnpm prettier . --write --config config/prettier/.prettierrc --ignore-path config/prettier/.prettierignore && pnpm exec stylelint 'quartz/**/*.scss' --config config/stylelint/.stylelintrc.json --fix",
    "test": "node --experimental-vm-modules --no-warnings --localstorage-file=/tmp/jest-localstorage.json node_modules/jest/bin/jest.js --coverage --config config/javascript/jest.config.js",
    "dev": "tsx quartz/bootstrap-cli.ts build --serve",
    "build": "tsx quartz/bootstrap-cli.ts build",
    "preview": "tsx quartz/bootstrap-cli.ts build && pnpm serve public",
    "start": "tsx quartz/bootstrap-cli.ts build && pnpm serve public -l 8080",
    "profile": "NODE_OPTIONS='--enable-source-maps' 0x --output-dir ./prof/ ./node_modules/.bin/tsx ./quartz/bootstrap-cli.ts build --concurrency=1",
    "postinstall": "patch-package",
    "install-browsers": "pnpm playwright install && npx puppeteer browsers install chrome",
    "test:visual": "pnpm playwright test --config config/playwright/playwright.config.ts --grep '(screenshot)'",
    "test:a11y": "pnpm pa11y-ci --config config/pa11y/.pa11yci --sitemap http://localhost:8080/sitemap.xml --sitemap-find https://turntrout.com --sitemap-replace http://localhost:8080 --sitemap-exclude '.*elk-proposal-thinking-via-a-human-imitator.*'",
    "generate:scss": "tsx quartz/styles/generate-variables.ts",
    "setup:python": "uv sync"
  },
  "lint-staged": {
    "*.{css,scss}": "pnpm exec stylelint --config config/stylelint/.stylelintrc.json --fix",
    "*.{js,jsx,ts,tsx}": "pnpm eslint --fix --config config/javascript/eslint.config.js",
    "{*.{css,scss,json,js,jsx,ts,tsx,md},.hooks/prepare-commit-msg}": "prettier --write --config config/prettier/.prettierrc --ignore-path config/prettier/.prettierignore",
    "*.fish": "fish_indent",
    "{*.sh,.hooks/commit-msg,.hooks/post-commit,.hooks/pre-commit,.hooks/pre-push}": [
      "shfmt -i 2 -w",
      "shellcheck"
    ],
    "*.py": [
      "ruff check --fix",
      "ruff format"
    ],
    "{*.md,.claude/**/*.md}": [
      "prettier --write --config config/prettier/.prettierrc --ignore-path config/prettier/.prettierignore",
      "markdownlint --config config/markdownlint/.markdownlint.jsonc --fix"
    ],
    "!(*.vale-styles|.claude)/**/*.md": "markdownlint --config config/markdownlint/.markdownlint.jsonc --fix"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "config": "config/javascript/commitlint.config.js"
  },
  "engines": {
    "pnpm": ">=9.0.0",
    "node": ">=22"
  },
  "packageManager": "pnpm@10.23.0",
  "keywords": [
    "site generator",
    "ssg",
    "digital-garden",
    "markdown",
    "blog",
    "quartz"
  ],
  "bin": {
    "quartz": "./quartz/bootstrap-cli.ts"
  },
